{
  "name": "ringtail-monorepo",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "services/*",
    "libs/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "echo 'Run ./tilt_up.sh (not tilt up) — Tilt owns dev servers, not Nx.'",
    "build": "nx run-many -t build",
    "typecheck": "nx run-many -t typecheck",
    "lint": "nx run-many -t lint",
    "check": "nx run-many -t typecheck lint",
    "check:no-leak": "bun test services/daemon/src/no-leak.test.ts",
    "check:docs": "bun test scripts/docs-sync.test.ts && cd apps/docs && bun run build",
    "demo": "bun services/daemon/src/demo-drive.ts",
    "demo:chat": "bun services/daemon/src/demo-chat.ts",
    "storybook": "storybook dev -p ${PORT:-6006} --no-open",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nx/eslint": "^23.0.1",
    "@nx/eslint-plugin": "^23.0.1",
    "@nx/js": "^23.0.1",
    "@storybook/addon-a11y": "^8.6.14",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/react": "^8.6.14",
    "@storybook/react-vite": "^8.6.14",
    "@types/node": "^20.11.1",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^10.6.0",
    "eslint-plugin-oxlint": "1.72.0",
    "lefthook": "^1.8.2",
    "nx": "^23.0.1",
    "oxfmt": "0.57.0",
    "oxlint": "1.72.0",
    "oxlint-tsgolint": "^0.24.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "^8.6.14",
    "typescript-eslint": "^8.62.1",
    "vite": "^6.0.7"
  },
  "packageManager": "bun@1.3.12",
  "overrides": {
    "bun-types": "1.1.34"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  }
}
