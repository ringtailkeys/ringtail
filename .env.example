# ─────────────────────────────────────────────────────────────────────────────
# Ringtail reads THIS FILE as the manifest — the shopping list.
#
# Every var below is a credential a typical project needs. Rocco walks this list,
# raids each provider's official token page (one human "allow" per provider, then
# zero-touch), scope-validates what he gets, and syncs it into `.env.local` AND
# Infisical across dev / staging / prod. Commented lines are on the list but not yet
# provisioned; uncomment to opt a var in. Never commit real values — this file holds
# names only.  ·  ringtailkeys.com
# ─────────────────────────────────────────────────────────────────────────────

# ── Cloudflare ──────────────────────────────────────────────────────────────
# Scoped API token (Workers/R2/DNS as the recipe requires) + account id.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# ── Database ────────────────────────────────────────────────────────────────
# Postgres connection string (local Postgres in dev, Neon/managed in prod).
DATABASE_URL=

# ── Auth ────────────────────────────────────────────────────────────────────
# Better Auth server secret — Ringtail can mint a strong random one locally.
BETTER_AUTH_SECRET=

# ── Email ───────────────────────────────────────────────────────────────────
# Resend API key for transactional mail.
RESEND_API_KEY=

# ── Product analytics ───────────────────────────────────────────────────────
# PostHog project key (public — client-inlined).
NEXT_PUBLIC_POSTHOG_KEY=

# ── Infisical (the secret sink) ─────────────────────────────────────────────
# Where Ringtail writes the provisioned keys per environment. The machine-identity
# client credentials + the project/env to target.
INFISICAL_CLIENT_ID=
INFISICAL_CLIENT_SECRET=
INFISICAL_PROJECT_ID=
INFISICAL_ENVIRONMENT=dev
