{
  "name": "@ringtail/docs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NEXT_TELEMETRY_DISABLED=1 next dev --port ${PORT:-4882}",
    "build": "NEXT_TELEMETRY_DISABLED=1 fumadocs-mdx && NEXT_TELEMETRY_DISABLED=1 next build",
    "start": "NEXT_TELEMETRY_DISABLED=1 next start"
  },
  "//": "No `typecheck` target on purpose: apps/docs is type-gated by `next build` (the check:docs CI job) — a separate tsc over the Next+Fumadocs type graph is redundant, slow, and OOMs.",
  "dependencies": {
    "fumadocs-core": "16.11.5",
    "fumadocs-ui": "16.11.5",
    "next": "16.3.0-preview.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/mdx": "^2.0.13",
    "@types/node": "^20.11.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "fumadocs-mdx": "15.2.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.0.0"
  },
  "nx": {
    "tags": [
      "type:app"
    ]
  }
}
