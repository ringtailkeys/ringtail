{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ringtail",
  "version": "0.1.0",
  "identifier": "com.ringtailkeys.app",
  "build": {
    "beforeDevCommand": "bun run prebuild:app",
    "beforeBuildCommand": "bun run prebuild:app",
    "frontendDist": "../splash"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Ringtail",
        "width": 1180,
        "height": 820,
        "minWidth": 720,
        "minHeight": 560,
        "resizable": true,
        "center": true,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 18, "y": 22 }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app", "nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../dashboard/dist": "dashboard"
    },
    "externalBin": ["binaries/ringtaild"],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
